# ==========================================
# GUI AI Agent 环境变量配置示例
# 请将此文件复制并重命名为 .env，然后填入你的真实配置
# ==========================================

# --- 全局重试配置 ---
# OCR 定位失败时的最大重试次数
OCR_RETRY=5
# 动作执行失败时的最大重试次数
DO_RETRY=5

# ==========================================
# 1. 文本模型 (LLM) 配置 (OpenAI 兼容格式)
# 用于将用户的自然语言指令拆解为具体的 GUI 动作
# 默认使用 DeepSeek，你也可以替换为其他兼容 OpenAI 格式的模型
# ==========================================
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com

# ==========================================
# 2. 视觉模型 (VLM) 配置
# 用于在动作执行后，通过截图验证任务是否成功，或理解屏幕内容
# ==========================================
# 选项 A: Ollama VL 模型配置 (推荐，同时也是 OCR 模型)
OLLAMA_HOST=http://127.0.0.1:11434

# 选项 B: 智谱 AI 视觉模型 VLM API KEY
ZHIPU_API_KEY=your_zhipu_api_key_here

# 选项 C: SiliconFlow VL API KEY
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ==========================================
# 3. OCR 模型配置
# 用于在屏幕截图中寻找目标文字或图标的物理坐标
# ==========================================
# 选项 A: 通义千问 OCR 模型
QWEN_OCR_API_KEY=your_qwen_api_key_here

# 选项 B: OpenRouter OCR 模型
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 选项 C: 百度 OCR API Keys (用于 gui_ocr.py 中的 BaiduTextAnchorService)
BAIDU_OCR_CLIENT_ID=your_baidu_client_id_here
BAIDU_OCR_CLIENT_SECRET=your_baidu_client_secret_here

# ==========================================
# 4. GUI 服务端与客户端配置
# ==========================================
# GUI 服务端
GUI_SERVER_URL=http://127.0.0.1:8001/api/run_for_agent

# GUI 客户端 (PC)
GUI_CLIENT_URL=http://127.0.0.1:8000/execute

# GUI 客户端 (Android)
GUI_CLIENT_URL_ANDROID=http://127.0.0.1:8000/execute

# ==========================================
# 5. Redis 配置
# 用于状态管理、防并发锁和历史轨迹存储
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=13

# ==========================================
# 提示：
# 有本地算力条件的推荐使用本地算力，因为视觉模型、OCR模型的花费比较大。
# 文本模型的要求不是很高，deepseek-r1:14b 基本就可以胜任。
# ==========================================
