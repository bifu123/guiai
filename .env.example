# ==========================================
# GUI AI Agent 环境变量配置示例
# 请将此文件复制并重命名为 .env，然后填入你的真实配置
# ==========================================

# --- 全局重试配置 ---
# OCR 定位失败时的最大重试次数
OCR_RETRY=5
# 动作执行失败时的最大重试次数
DO_RETRY=5

# ==========================================
# 1. 意图解析大模型 (LLM) 配置
# 用于将用户的自然语言指令拆解为具体的 GUI 动作
# 默认使用 DeepSeek，你也可以替换为其他兼容 OpenAI 格式的模型
# ==========================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ==========================================
# 2. 视觉验证大模型 (VLM) 配置
# 用于在动作执行后，通过截图验证任务是否成功
# 默认使用智谱 GLM-4V
# ==========================================
ZHIPU_API_KEY=your_zhipu_api_key_here

# ==========================================
# 3. 视觉定位模型 (OCR/Grounding) 配置
# 用于在屏幕截图中寻找目标文字或图标的物理坐标
# ==========================================

# 选项 A: 阿里云 Qwen-VL-OCR (推荐，速度快，准确率高)
QWEN_OCR_API_KEY=your_qwen_api_key_here

# 选项 B: OpenRouter 免费视觉模型 (备用方案)
OPENROUTER_API_KEY=your_openrouter_api_key_here
